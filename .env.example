EODHD_API_KEY=your_eodhd_api_key_here
SEC_USER_AGENT=TatetuckBot/1.0 ops@example.com
TATETUCK_STORE_DIR=.tatetuck_store
TATETUCK_INCLUDE_LITERATURE=false
APCA_API_KEY_ID=your_alpaca_paper_key_id_here
APCA_API_SECRET_KEY=your_alpaca_paper_secret_key_here
APCA_API_BASE_URL=https://paper-api.alpaca.markets
APCA_PAPER_ACCOUNT_ID=your_alpaca_paper_account_number_here
TATETUCK_MIN_SNAPSHOT_DATES=10
TATETUCK_MIN_MATURED_RETURN_ROWS=100
TATETUCK_MIN_WALKFORWARD_WINDOWS=3
TATETUCK_MAX_SNAPSHOT_AGE_HOURS=36
TATETUCK_MIN_ARCHIVE_RUNS=1
TATETUCK_MAX_GROSS_EXPOSURE_PCT=18
TATETUCK_MAX_SINGLE_POSITION_PCT=4
TATETUCK_MIN_EXECUTION_WEIGHT_PCT=1
TATETUCK_MIN_EXECUTION_CONFIDENCE=0.60
TATETUCK_MIN_ORDER_NOTIONAL=150
TATETUCK_MAX_NEW_POSITIONS=6
TATETUCK_ALLOW_BLOCKED_PAPER_TRADING=false
TATETUCK_SIMULATED_PAPER_EQUITY=100000
