TATETUCK_MIN_MATURED_RETURN_ROWS=100
TATETUCK_MIN_WALKFORWARD_WINDOWS=3
TATETUCK_MAX_SNAPSHOT_AGE_HOURS=36
TATETUCK_MIN_ARCHIVE_RUNS=1
