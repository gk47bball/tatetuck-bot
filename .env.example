EODHD_API_KEY=your_eodhd_api_key_here
SEC_USER_AGENT=TatetuckBot/1.0 ops@example.com
TATETUCK_STORE_DIR=.tatetuck_store
TATETUCK_INCLUDE_LITERATURE=false
